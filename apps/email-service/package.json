{
  "name": "@ecommerce/email-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "pnpm --filter @ecommerce/config --filter @ecommerce/logger build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ecommerce/config": "workspace:*",
    "@ecommerce/logger": "workspace:*",
    "fastify": "^5.0.0",
    "pino": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
