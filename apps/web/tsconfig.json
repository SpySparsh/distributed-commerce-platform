{
  "extends": "../../packages/config/tsconfig/next.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@web/*": [
        "apps/web/src/*"
      ],
      "@ecommerce/config": [
        "packages/config/src/index.ts"
      ],
      "@ecommerce/types": [
        "packages/types/src/index.ts"
      ],
      "@ecommerce/ui": [
        "packages/ui/src/index.ts"
      ],
      "react-router-dom": [
        "apps/web/src/lib/router.tsx"
      ]
    },
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
