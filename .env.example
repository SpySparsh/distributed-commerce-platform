NODE_ENV=development

# Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000
API_PORT=4000
WORKER_CONCURRENCY=5
WORKER_SHUTDOWN_GRACE_MS=10000
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SLOW_API_THRESHOLD_MS=500
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Infrastructure
# Supabase Postgres. Use the Supavisor Session pooler URL on port 5432 for local Node.js development.
# Format: postgresql://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
DATABASE_URL=postgresql://prisma.project-ref:replace-with-prisma-password@aws-0-region.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
# Required for Prisma CLI commands and migrations. Use a Supabase direct/session-safe connection, not the transaction pooler.
DIRECT_URL=postgresql://postgres.project-ref:replace-with-postgres-password@aws-0-region.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
REDIS_URL=redis://localhost:6379
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=development-master-key
MEILISEARCH_INDEX_PREFIX=ecommerce
MEILI_ENV=development

# Database bootstrap
SEED_TENANT_NAME=Demo Store
SEED_TENANT_SLUG=demo-store
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe12345

# Payments
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

# Auth
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-access
REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters-refresh
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_SECURE=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# Legacy runtime during migration
MONGO_URI=mongodb://localhost:27017/ecommerce
JWT_SECRET=replace-with-at-least-32-characters
