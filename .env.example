NODE_ENV=development

# Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000
WORKER_CONCURRENCY=5
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Infrastructure
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public
REDIS_URL=redis://localhost:6379

# Auth
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-access
REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters-refresh
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_SECURE=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# Legacy runtime during migration
MONGO_URI=mongodb://localhost:27017/ecommerce
JWT_SECRET=replace-with-at-least-32-characters
