{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": "..",
    "paths": {
      "@ecommerce/shared": ["packages/shared/src/index.ts"],
      "@ecommerce/shared/*": ["packages/shared/src/*"],
      "@web/*": ["ecommerce-frontend/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.jsx", "vite.config.js"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../packages/shared" }]
}
