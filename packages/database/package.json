{
  "name": "@ecommerce/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma.config.ts",
    "db:migrate:dev": "prisma migrate dev --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:reset": "prisma migrate reset --force --skip-generate --skip-seed --config prisma.config.ts && pnpm run db:generate && pnpm run db:seed",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:generate": "pnpm run db:generate",
    "prisma:migrate": "pnpm run db:migrate:dev",
    "prisma:validate": "prisma validate --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
