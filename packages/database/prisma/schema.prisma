generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  active
  suspended
  archived
}

enum UserStatus {
  active
  invited
  suspended
  deleted
}

enum ProductStatus {
  draft
  active
  archived
}

enum CartStatus {
  active
  converted
  abandoned
  expired
}

enum OrderStatus {
  pending
  confirmed
  paid
  fulfilled
  cancelled
  refunded
}

enum OrderEventType {
  created
  confirmed
  paid
  fulfilled
  cancelled
  refunded
  payment_synced
  inventory_consumed
  invoice_requested
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
  cancelled
}

enum PaymentWebhookStatus {
  received
  processed
  ignored
  failed
}

enum PaymentProvider {
  stripe
  razorpay
  cod
  manual
}

enum InventoryReservationStatus {
  active
  consumed
  released
  expired
}

enum DomainEventStatus {
  pending
  published
  consumed
  failed
}

enum AuditAction {
  create
  update
  delete
  restore
  login
  logout
  checkout
  order
  payment
  inventory_adjustment
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?    @db.Timestamptz(6)

  users                 User[]
  roles                 Role[]
  userRoles             UserRole[]
  permissions           Permission[]
  rolePermissions       RolePermission[]
  sessions              Session[]
  categories            Category[]
  products              Product[]
  productVariants       ProductVariant[]
  productImages         ProductImage[]
  carts                 Cart[]
  orders                Order[]
  orderEvents           OrderEvent[]
  payments              Payment[]
  paymentWebhookEvents  PaymentWebhookEvent[]
  domainEvents          DomainEventLog[]
  inventoryItems        InventoryItem[]
  inventoryReservations InventoryReservation[]
  auditLogs             AuditLog[]

  @@index([status, deletedAt])
  @@index([createdAt, id])
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @db.Uuid
  email        String
  passwordHash String
  firstName    String?
  lastName     String?
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?  @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sessions  Session[]
  userRoles UserRole[]
  carts     Cart[]
  orders    Order[]
  auditLogs AuditLog[] @relation("ActorAuditLogs")

  @@unique([tenantId, email])
  @@index([tenantId, status, deletedAt])
  @@index([tenantId, createdAt, id])
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  expiresAt    DateTime  @db.Timestamptz(6)
  revokedAt    DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, revokedAt])
  @@index([tenantId, expiresAt])
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  key         String
  name        String
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId, deletedAt])
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  key         String
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId, deletedAt])
}

model UserRole {
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId, roleId])
  @@index([tenantId, roleId])
}

model RolePermission {
  tenantId     String   @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([tenantId, roleId, permissionId])
  @@index([tenantId, permissionId])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  parentId    String?   @db.Uuid
  name        String
  slug        String
  description String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId, parentId, position])
  @@index([tenantId, deletedAt])
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  categoryId  String?       @db.Uuid
  sku         String
  slug        String
  name        String
  description String?
  status      ProductStatus @default(draft)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?     @db.Timestamptz(6)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants ProductVariant[]
  images   ProductImage[]
  cartItems CartItem[]
  orderItems OrderItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, slug])
  @@index([tenantId, status, deletedAt, createdAt, id])
  @@index([tenantId, status, deletedAt, updatedAt, id])
  @@index([tenantId, categoryId, status, deletedAt])
  @@index([tenantId, name])
}

model ProductVariant {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  productId      String        @db.Uuid
  sku            String
  name           String
  attributes     Json          @default("{}")
  price          Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?      @db.Decimal(12, 2)
  currency       String        @default("USD") @db.Char(3)
  status         ProductStatus @default(active)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?     @db.Timestamptz(6)

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem         InventoryItem?
  cartItems             CartItem[]
  orderItems            OrderItem[]
  inventoryReservations InventoryReservation[]

  @@unique([tenantId, sku])
  @@index([tenantId, productId, status, deletedAt])
  @@index([tenantId, status, createdAt, id])
}

model ProductImage {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  productId String    @db.Uuid
  url       String
  altText   String?
  position  Int       @default(0)
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId, position])
  @@index([tenantId, productId, isPrimary])
  @@index([tenantId, deletedAt])
}

model InventoryItem {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  variantId   String    @unique @db.Uuid
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  safetyStock Int       @default(0)
  version     Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@index([tenantId, variantId])
  @@index([tenantId, updatedAt, id])
}

model InventoryReservation {
  id              String                     @id @default(uuid()) @db.Uuid
  tenantId        String                     @db.Uuid
  inventoryItemId String                     @db.Uuid
  variantId       String                     @db.Uuid
  cartItemId      String?                    @db.Uuid
  orderItemId     String?                    @db.Uuid
  idempotencyKey  String?
  quantity        Int
  status          InventoryReservationStatus @default(active)
  expiresAt       DateTime                   @db.Timestamptz(6)
  releasedAt      DateTime?                  @db.Timestamptz(6)
  consumedAt      DateTime?                  @db.Timestamptz(6)
  createdAt       DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime?                  @db.Timestamptz(6)

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  inventoryItem InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  variant       ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  cartItem      CartItem?       @relation(fields: [cartItemId], references: [id], onDelete: SetNull)
  orderItem     OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, expiresAt])
  @@index([tenantId, inventoryItemId, status])
  @@index([tenantId, variantId, status, expiresAt])
  @@index([tenantId, cartItemId])
  @@index([tenantId, orderItemId])
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @db.Uuid
  userId    String?    @db.Uuid
  guestId   String?
  deviceId  String?
  status    CartStatus @default(active)
  version   Int        @default(0)
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @db.Timestamptz(6)
  lastSyncedAt DateTime? @db.Timestamptz(6)
  expiresAt DateTime?  @db.Timestamptz(6)
  deletedAt DateTime?  @db.Timestamptz(6)

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items  CartItem[]
  orders Order[]

  @@index([tenantId, userId, status])
  @@index([tenantId, guestId, status])
  @@index([tenantId, deviceId, status])
  @@index([tenantId, status, updatedAt, id])
  @@index([tenantId, expiresAt])
}

model CartItem {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  cartId    String    @db.Uuid
  productId String    @db.Uuid
  variantId String    @db.Uuid
  quantity  Int
  unitPrice Decimal   @db.Decimal(12, 2)
  currency  String    @default("USD") @db.Char(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  cart         Cart                   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@unique([tenantId, cartId, variantId])
  @@index([tenantId, cartId, createdAt, id])
  @@index([tenantId, variantId])
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  userId          String?     @db.Uuid
  cartId          String?     @db.Uuid
  orderNumber     String
  status          OrderStatus @default(pending)
  subtotalAmount  Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  shippingAmount  Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("USD") @db.Char(3)
  email           String
  shippingAddress Json
  billingAddress  Json?
  invoiceNumber   String?
  invoiceUrl      String?
  placedAt        DateTime?   @db.Timestamptz(6)
  invoicedAt      DateTime?   @db.Timestamptz(6)
  version         Int         @default(0)
  createdAt       DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime?   @db.Timestamptz(6)

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  cart     Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  events   OrderEvent[]
  payments Payment[]

  @@unique([tenantId, orderNumber])
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, userId, createdAt, id])
  @@index([tenantId, status, createdAt, id])
  @@index([tenantId, email, createdAt])
  @@index([tenantId, placedAt, id])
}

model OrderEvent {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @db.Uuid
  orderId      String         @db.Uuid
  type         OrderEventType
  beforeStatus OrderStatus?
  afterStatus  OrderStatus?
  actorUserId  String?        @db.Uuid
  requestId    String?
  reason       String?
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?      @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([tenantId, actorUserId, createdAt])
}

model OrderItem {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  orderId     String    @db.Uuid
  productId   String    @db.Uuid
  variantId   String    @db.Uuid
  sku         String
  name        String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalAmount Decimal   @db.Decimal(12, 2)
  currency    String    @default("USD") @db.Char(3)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@index([tenantId, orderId])
  @@index([tenantId, variantId, createdAt])
}

model Payment {
  id                    String          @id @default(uuid()) @db.Uuid
  tenantId              String          @db.Uuid
  orderId               String          @db.Uuid
  provider              PaymentProvider
  status                PaymentStatus   @default(pending)
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("USD") @db.Char(3)
  providerPaymentId     String?
  providerTransactionId String?
  idempotencyKey        String
  failureCode           String?
  failureMessage        String?
  retryCount            Int             @default(0)
  nextRetryAt           DateTime?       @db.Timestamptz(6)
  metadata              Json            @default("{}")
  authorizedAt          DateTime?       @db.Timestamptz(6)
  capturedAt            DateTime?       @db.Timestamptz(6)
  failedAt              DateTime?       @db.Timestamptz(6)
  refundedAt            DateTime?       @db.Timestamptz(6)
  createdAt             DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt             DateTime?       @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, provider, providerPaymentId])
  @@index([tenantId, orderId, status])
  @@index([tenantId, status, createdAt, id])
  @@index([tenantId, status, nextRetryAt])
}

model PaymentWebhookEvent {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @db.Uuid
  provider        PaymentProvider
  providerEventId String
  eventType       String
  status          PaymentWebhookStatus @default(received)
  payload         Json
  receivedAt      DateTime             @default(now()) @db.Timestamptz(6)
  processedAt     DateTime?            @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime?            @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, provider, providerEventId])
  @@index([tenantId, provider, eventType, receivedAt])
  @@index([tenantId, status, receivedAt])
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  actorUserId  String?     @db.Uuid
  action       AuditAction
  entityType   String
  entityId     String      @db.Uuid
  requestId    String?
  ipAddress    String?
  userAgent    String?
  before       Json?
  after        Json?
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?   @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User?  @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId, createdAt])
  @@index([tenantId, actorUserId, createdAt])
  @@index([tenantId, action, createdAt])
  @@index([tenantId, createdAt, id])
}

model DomainEventLog {
  id            String            @id @db.Uuid
  tenantId      String            @db.Uuid
  name          String
  aggregateType String
  aggregateId   String            @db.Uuid
  correlationId String?
  causationId   String?           @db.Uuid
  actorUserId   String?           @db.Uuid
  schemaVersion Int               @default(1)
  payload       Json
  status        DomainEventStatus @default(pending)
  occurredAt    DateTime          @db.Timestamptz(6)
  publishedAt   DateTime?         @db.Timestamptz(6)
  consumedAt    DateTime?         @db.Timestamptz(6)
  failedAt      DateTime?         @db.Timestamptz(6)
  failureReason String?
  createdAt     DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?         @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, name, occurredAt])
  @@index([tenantId, aggregateType, aggregateId, occurredAt])
  @@index([tenantId, status, occurredAt])
  @@index([correlationId])
}
