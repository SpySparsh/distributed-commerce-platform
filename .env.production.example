NODE_ENV=production

# Images
REGISTRY_IMAGE=ghcr.io/your-org/ecommerce
IMAGE_TAG=latest

# Public networking
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=https://api.example.com
CORS_ORIGIN=https://www.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Runtime
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SLOW_API_THRESHOLD_MS=500
REQUEST_ID_HEADER=x-request-id
SHUTDOWN_GRACE_MS=10000
WORKER_CONCURRENCY=10
WORKER_SHUTDOWN_GRACE_MS=10000

# Rate limits
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=10

DATABASE_URL=postgresql://prisma.project-ref:replace-with-prisma-password@aws-0-region.pooler.supabase.com:5432/postgres?schema=public&sslmode=require
DIRECT_URL=postgresql://postgres.project-ref:replace-with-postgres-password@aws-0-region.pooler.supabase.com:5432/postgres?schema=public&sslmode=require

# Redis
REDIS_URL=redis://redis:6379

# Meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=replace-with-strong-meili-master-key
MEILISEARCH_INDEX_PREFIX=ecommerce

# Database bootstrap. Use once during environment provisioning, then rotate/remove the password.
SEED_TENANT_NAME=Production Store
SEED_TENANT_SLUG=production-store
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-temporary-admin-password

# Auth
ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
REFRESH_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_SECURE=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# Payments
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
